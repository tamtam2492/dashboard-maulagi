# Supabase
SUPABASE_URL=https://your-project.supabase.co

# (Opsional) Publishable/anon key bila nanti ada akses client-side langsung ke Supabase
SUPABASE_ANON_KEY=your-anon-key-here

# Wajib untuk API server dan script maintenance yang menulis/menghapus data
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# (Opsional) CORS origin
ALLOWED_ORIGIN=https://your-domain.vercel.app

# (Opsional) Kredensial MAUKIRIM untuk auto sync data noncod/dfod
MAUKIRIM_WA=628xxxxxxxxxx
MAUKIRIM_PASS=your-maukirim-password

# (Opsional) OCR bukti transfer via Groq
GROQ_API_KEY=your-groq-api-key

# (Opsional) AWS Lambda notifier Telegram
# Isi dengan Lambda Function URL atau API Gateway URL
TELEGRAM_NOTIFY_URL=https://your-lambda-url.lambda-url.ap-southeast-1.on.aws/

# Shared secret antara Vercel/API ini dan AWS Lambda notifier
TELEGRAM_NOTIFY_SECRET=your-shared-secret

# Sumber error yang boleh diteruskan ke Telegram, pisahkan dengan koma
# Contoh awal aman: noncod,auth
TELEGRAM_NOTIFY_SOURCES=noncod

# Nama service yang tampil di notifikasi
TELEGRAM_NOTIFY_SERVICE=dashboard-maulagi-prod

# Timeout request ke notifier dalam ms
TELEGRAM_NOTIFY_TIMEOUT_MS=2500

# (Opsional) Redis REST untuk rate limiter multi-instance
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# (Opsional) Path file XLSX untuk script migrasi lokal
EXCEL_PATH=C:/path/to/source.xlsx

