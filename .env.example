# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# (Opsional) CORS origin
ALLOWED_ORIGIN=https://your-domain.vercel.app

# (Opsional) Kredensial MAUKIRIM untuk auto sync data noncod/dfod
MAUKIRIM_WA=628xxxxxxxxxx
MAUKIRIM_PASS=your-maukirim-password

# (Opsional) OCR bukti transfer via Groq
GROQ_API_KEY=your-groq-api-key

# (Opsional) Redis REST untuk rate limiter multi-instance
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# (Opsional) Path file XLSX untuk script migrasi lokal
EXCEL_PATH=C:/path/to/source.xlsx

