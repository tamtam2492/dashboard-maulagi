# Supabase
SUPABASE_URL=https://your-project.supabase.co

# (Opsional) Publishable/anon key bila nanti ada akses client-side langsung ke Supabase
SUPABASE_ANON_KEY=your-anon-key-here

# Wajib untuk API server dan script maintenance yang menulis/menghapus data
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# (Opsional) CORS origin
ALLOWED_ORIGIN=https://your-domain.vercel.app

# (Opsional) Kredensial MAUKIRIM untuk auto sync data noncod/dfod
MAUKIRIM_WA=628xxxxxxxxxx
MAUKIRIM_PASS=your-maukirim-password

# (Opsional) OCR bukti transfer via Groq
# Jika OCR diproses di Lambda, isi di env Lambda worker.
# Jika OCR masih memakai self-trigger fallback ke Vercel, isi juga di env Vercel.
GROQ_API_KEY=your-groq-api-key

# (Opsional) Secret worker internal OCR di Vercel
# Jika app berjalan di Vercel dan OCR_PIPELINE_TRIGGER_URL tidak diisi,
# backend akan self-trigger ke https://$VERCEL_URL/api/input?ocr=1&worker=1 memakai secret ini.
OCR_SYNC_SECRET=your-vercel-ocr-worker-secret

# (Opsional) Override trigger background untuk pipeline OCR
# Production multi-user sebaiknya isi ini ke Lambda/custom URL,
# agar OCR tidak berbagi concurrency yang sama dengan API input Vercel.
OCR_PIPELINE_TRIGGER_URL=https://your-ocr-worker-url.example.com/
OCR_PIPELINE_TRIGGER_SECRET=your-ocr-trigger-secret
OCR_PIPELINE_TRIGGER_TIMEOUT_MS=15000

# (Opsional) AWS Lambda notifier Telegram
# Isi dengan Lambda Function URL atau API Gateway URL
TELEGRAM_NOTIFY_URL=https://your-lambda-url.lambda-url.ap-southeast-1.on.aws/

# Shared secret antara Vercel/API ini dan AWS Lambda notifier
TELEGRAM_NOTIFY_SECRET=your-shared-secret

# Sumber error yang boleh diteruskan ke Telegram, pisahkan dengan koma
# Contoh awal aman: noncod,auth
TELEGRAM_NOTIFY_SOURCES=noncod

# Nama service yang tampil di notifikasi
TELEGRAM_NOTIFY_SERVICE=dashboard-maulagi-prod

# Timeout request ke notifier dalam ms
TELEGRAM_NOTIFY_TIMEOUT_MS=2500

# (Opsional) Redis REST untuk rate limiter multi-instance
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# (Opsional) Secret endpoint worker internal NONCOD di Vercel
# Jika app berjalan di Vercel dan NONCOD_PIPELINE_TRIGGER_URL tidak diisi,
# backend akan self-trigger ke https://$VERCEL_URL/api/noncod-sync memakai secret ini.
NONCOD_SYNC_SECRET=your-vercel-sync-endpoint-secret

# (Opsional) Override trigger background untuk pipeline NONCOD
# Isi jika trigger harus diarahkan ke Lambda/custom URL, bukan self-trigger langsung.
NONCOD_PIPELINE_TRIGGER_URL=https://your-trigger-url.example.com/
NONCOD_PIPELINE_TRIGGER_SECRET=your-trigger-secret
NONCOD_PIPELINE_TRIGGER_TIMEOUT_MS=2500

