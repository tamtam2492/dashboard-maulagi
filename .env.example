# =============================================================================
# LEGEND:
#   [SELF]     = buat sendiri, nilai bebas (misal: string acak via `openssl rand -hex 32`)
#   [EXTERNAL] = ambil dari dashboard layanan eksternal (langkah di bawah tiap env)
#   [AUTO]     = diisi otomatis oleh platform (Vercel), tidak perlu diisi manual
#   [CONFIG]   = nilai konfigurasi biasa, bukan secret
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE  [EXTERNAL]
# Langkah: https://supabase.com/dashboard → pilih project → Settings → API
#   - "Project URL"          → SUPABASE_URL
#   - "anon / public"        → SUPABASE_ANON_KEY
#   - "service_role secret"  → SUPABASE_SERVICE_ROLE_KEY (klik "Reveal")
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# -----------------------------------------------------------------------------
# CORS  [CONFIG]
# Isi dengan domain production Vercel kamu
# -----------------------------------------------------------------------------
ALLOWED_ORIGIN=https://your-domain.vercel.app


# -----------------------------------------------------------------------------
# MAUKIRIM  [EXTERNAL]
# Langkah: login ke app MAUKIRIM → Pengaturan → Akun
#   - Nomor WA aktif        → MAUKIRIM_WA
#   - Password akun         → MAUKIRIM_PASS
# -----------------------------------------------------------------------------
MAUKIRIM_WA=628xxxxxxxxxx
MAUKIRIM_PASS=your-maukirim-password


# -----------------------------------------------------------------------------
# GROQ API KEY  [EXTERNAL]
# Langkah: https://console.groq.com → API Keys → Create API Key → Copy
# -----------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key


# -----------------------------------------------------------------------------
# OCR INTERNAL SECRETS  [SELF]
# Buat nilai acak sendiri, contoh: openssl rand -hex 32
# Dipakai untuk autentikasi request internal antar endpoint Vercel
# -----------------------------------------------------------------------------
OCR_SYNC_SECRET=your-vercel-ocr-worker-secret

# (Opsional) Jika OCR di-offload ke Lambda/worker eksternal
OCR_PIPELINE_TRIGGER_URL=https://your-ocr-worker-url.example.com/
OCR_PIPELINE_TRIGGER_SECRET=your-ocr-trigger-secret   # [SELF]
OCR_PIPELINE_TRIGGER_TIMEOUT_MS=15000                  # [CONFIG]


# -----------------------------------------------------------------------------
# TELEGRAM NOTIFIER  [CAMPURAN]
# TELEGRAM_NOTIFY_URL  [EXTERNAL] — dari AWS Lambda:
#   AWS Console → Lambda → pilih function → Configuration → Function URL → Copy URL
# TELEGRAM_NOTIFY_SECRET  [SELF] — buat acak, isi sama di Lambda env dan di sini
# TELEGRAM_BOT_TOKEN  [EXTERNAL] — dari @BotFather di Telegram → /mybots → token
# TELEGRAM_CHAT_ID   [EXTERNAL] — kirim pesan ke bot → cek via
#   https://api.telegram.org/bot<TOKEN>/getUpdates → ambil "chat.id"
# -----------------------------------------------------------------------------
TELEGRAM_NOTIFY_URL=https://your-lambda-url.lambda-url.ap-southeast-1.on.aws/
TELEGRAM_NOTIFY_SECRET=your-shared-secret             # [SELF]
TELEGRAM_NOTIFY_SOURCES=noncod                        # [CONFIG]
TELEGRAM_NOTIFY_SERVICE=dashboard-maulagi-prod        # [CONFIG]
TELEGRAM_NOTIFY_TIMEOUT_MS=2500                       # [CONFIG]
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id


# -----------------------------------------------------------------------------
# UPSTASH REDIS (Rate Limiter)  [EXTERNAL]
# Langkah: https://console.upstash.com → pilih database → REST API tab
#   - "UPSTASH_REDIS_REST_URL"   → copy URL
#   - "UPSTASH_REDIS_REST_TOKEN" → klik "Copy" di kolom token
# Alternatif via Vercel KV Integration (auto-populated):
#   Vercel Dashboard → Storage → Connect → KV → env otomatis ter-set
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Alias dari Vercel KV Integration  [AUTO]
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your-kv-token

# Emergency fallback ke memory (biarkan 0 di production)  [CONFIG]
RATE_LIMIT_ALLOW_MEMORY_FALLBACK=0


# -----------------------------------------------------------------------------
# NONCOD LEGACY WORKER METADATA  [OPTIONAL]
# Jalur refresh NONCOD aktif sekarang adalah upload workbook manual admin.
# Kosongkan nilai di bawah ini bila worker NONCOD sudah tidak dipakai.
# -----------------------------------------------------------------------------
NONCOD_SYNC_SECRET=
NONCOD_PIPELINE_TRIGGER_URL=
NONCOD_PIPELINE_TRIGGER_SECRET=
NONCOD_PIPELINE_TRIGGER_TIMEOUT_MS=2500               # [CONFIG]


# -----------------------------------------------------------------------------
# VERCEL CRON SECRET  [SELF]
# Langkah: buat nilai acak → isi di sini DAN di vercel.json bagian crons header
#   Contoh generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=your-cron-secret


# -----------------------------------------------------------------------------
# TUNING  [CONFIG]
# Nilai ms, sesuaikan jika perlu
# -----------------------------------------------------------------------------
AUTH_SLOW_TIMEOUT_MS=10000

